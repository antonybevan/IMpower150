# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ─── Runtime Databases (never commit live DB blobs) ──────────────────────
*.db
*.sqlite
*.sqlite3
*.duckdb

# ─── Generated Outputs (runtime artifacts, not source) ────────────────────
outputs/
outputs/datasets/
outputs/logs/
outputs/manifests/
outputs/submission/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.local
venv/
.venv/
env/

# ─── Node (for assets/ TSX builds) ───────────────────────────────────────
node_modules/
dist/
dist-ssr/

# ─── Editor ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Alembic ──────────────────────────────────────────────────────────────
